{
  "manifest_version": 3,
  "name": "Okta Expression Builder",
  "version": "1.0.0",
  "description": "Build and live-preview Okta Expression Language (OEL) expressions directly in the Okta admin console.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://*.okta.com/*",
        "https://*.okta-emea.com/*",
        "https://*.oktapreview.com/*",
        "https://*.okta-gov.com/*",
        "https://*.okta-gov.us/*"
      ],
      "js": ["evaluator.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_title": "Okta Expression Builder",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  }
}
